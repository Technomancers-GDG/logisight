# Backend Environment Configuration
# Copy this to .env and fill in actual values for your environment.

# Application
APP_NAME=Resilient Essential Goods Coordinator
DEMO_MODE=true
ALLOW_DEMO_SEED=true

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/supply_chain

# Simulation
SIMULATION_START_DATE=2026-01-01
SIMULATION_SPEED=5000.0
ROUTE_USE_OSRM=true
ROUTE_USE_OSMNX=false
OSMNX_GRAPH_PATH=data/osmnx_graph.graphml
OSMNX_GRAPHS_DIR=data/osmnx_graphs
OSRM_BASE_URL=https://router.project-osrm.org

# Redis (horizontal WebSocket scaling — set USE_REDIS=true and REDIS_URL for production)
USE_REDIS=false
REDIS_URL=

# Authentication
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Google Cloud
GCP_PROJECT_ID=logisight-prod
GCP_REGION=asia-south1
FIREBASE_ENABLED=false
PUBSUB_ENABLED=false
VERTEX_AI_ENABLED=false
BIGQUERY_ENABLED=false
BIGQUERY_DATASET=supply_chain
FCM_ENABLED=false

# AI / LLM
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant,mixtral-8x7b-32768,gemma2-9b-it,llama-3.2-3b-preview
AI_RATE_LIMIT_PER_MIN=10

# RL & Optimization
USE_RL_ENGINE=true
USE_NSGA2_OPTIMIZER=true
RL_MODEL_PATH=data/rl_model.json

# Cryptographic Audit Trail (SHA-256 hash-chain)
AUDIT_LEDGER_PATH=data/audit_ledger.json

# Cost Calibration
COST_POINT_TO_INR=15.0

# Demo Disruption
DEMO_DISRUPTION_DELAY_SECONDS=4
DEMO_DISRUPTION_CITY=Chennai
DEMO_DISRUPTION_SEVERITY=0.82

# News / Weather Data
NEWS_DATASET_PATH=All_Cities_News_v2.xlsx
WEATHER_DATASET_PATH=Historical_Weather_Data_2024_2026.xlsx
NEWS_MODEL_ARTIFACT_PATH=news_model.pkl

# Redis (horizontal WebSocket scaling)
# Set USE_REDIS=true + REDIS_URL=redis://... to relay broadcasts across
# multiple application instances via Redis Pub/Sub (Upstash, ElastiCache, etc.).
# When disabled broadcasts are local-only (single-process).
USE_REDIS=false
REDIS_URL=

# API Key Auth (used for demo/mock endpoints authenticated via X-API-Key header)
# When DEMO_MODE=true, all routes accept a missing/invalid key automatically.
# In production, set a strong, unique value for MOCK_API_KEY.
MOCK_API_KEY=

# CORS
CORS_ORIGINS=
